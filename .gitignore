profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you may or may not want to do so.
# .python-version

# pipenv
#   According to pypa/pipenv#1010, the submission of Pipfile.lock to git is highly recommended.
#   However, Pipfile.lock should contain the locked packages.
#   Pipfile.lock is generally recommended to be committed for apps but ignored for libraries.
# Pipfile.lock

# poetry
#   Similarly, poetry.lock is generally recommended to be committed for apps but ignored for libraries.
# poetry.lock

# pdm
#   Similarly, pdm.lock is generally recommended to be committed for apps but ignored for libraries.
# pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

